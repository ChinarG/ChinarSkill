{
  "id": "feishu-video-sender",
  "name": "Feishu Video Sender",
  "description": "Send video files to Feishu/Lark via API",
  "version": "1.0.0",
  "entry": "src/send-video.py",
  "configSchema": {
    "type": "object",
    "properties": {
      "appId": {
        "type": "string",
        "description": "Feishu App ID"
      },
      "appSecret": {
        "type": "string",
        "description": "Feishu App Secret"
      },
      "defaultReceiveId": {
        "type": "string",
        "description": "Default user open_id to send to"
      }
    },
    "required": ["appId", "appSecret"]
  }
}
